{
	"multi": {
		"type": "container",
		"classList": [
			"col",
			"justify-start",
			"text-center"
		],
		"attributes": [
			"custom-padding"
		],
		"elements": [
			{
				"type": "image",
				"alt": "website",
				"size": "large",
				"src": "/files/images/icons/web_design/black/website-icon.svg",
				"attributes": [
					"custom-margin"
				],
				"properties": [
					{
						"key": "--margin-mult",
						"value": "1"
					}
				]
			},
			{
				"type": "headline",
				"tag": "h3",
				"size": "x-small",
				"content": "Design and build scalable web solutions."
			},
			{
				"type": "text",
				"tag": "p",
				"content": "Your website is the center of your online presence. It's also the hub for all your important business apps. Empac can build you a website that'll get your customers engaged and provide an easy path towards scalability."
			},
			{
				"type": "container",
				"classList": [
					"cta-section",
					"row",
					"align-center"
				],
				"attributes": [
					"h-center"
				],
				"elements": [
					{
						"type": "link",
						"classList": [
							"btn",
							"primary",
							"brand"
						],
						"content": "Check it out",
						"aria_label": "Click to check out website services",
						"href": "/services/website/"
					}
				]
			}
		]
	}
}