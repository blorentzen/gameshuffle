{
	"multi": {
		"type": "container",
		"classList": [
			"col",
			"justify-start",
			"text-center"
		],
		"attributes": [
			"custom-padding"
		],
		"elements": [
			{
				"type": "image",
				"alt": "website",
				"size": "large",
				"src": "/files/images/icons/marketing/black/strategy-icon.svg",
				"attributes": [
					"custom-margin"
				],
				"properties": [
					{
						"key": "--margin-mult",
						"value": "1"
					}
				]
			},
			{
				"type": "headline",
				"tag": "h3",
				"size": "x-small",
				"content": "Get your audience engaged with you online."
			},
			{
				"type": "text",
				"tag": "p",
				"content": "There's all kinds of places your customers can be at online, and you'll need a partner that can find the best ways to reach them. Empac can work with you on a digital marketing strategy that will improve your reach and conversion."
			},
			{
				"type": "container",
				"classList": [
					"cta-section",
					"row",
					"align-center"
				],
				"attributes": [
					"h-center"
				],
				"elements": [
					{
						"type": "link",
						"classList": [
							"btn",
							"primary",
							"brand"
						],
						"content": "Check it out",
						"aria_label": "Click to check out marketing services",
						"href": "/services/marketing/"
					}
				]
			}
		]
	}
}