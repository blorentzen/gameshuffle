{
	"type":"container",
	"id":"marketingCarousel",
	"classList":["container", "has_carousel"],
	"attributes":["anim-drop-fade", "custom-margin"],
	"properties":[
		{ "key":"--padding-mult", "value":"2"},
		{ "key":"--margin-mult", "value":"2"},
		{"key": "--card-width", "value": "350px"},
		{"key": "--card-width-mob", "value": "80vw"}
	],
	"elements":[ 
		{
			"type": "container",
			"classList": ["content", "text-center"],
			"attributes": ["custom-margin"],
			"properties": [
				{ "key":"--margin-mult", "value":"4"}
			],
			"elements": [
				{
					"type": "headline",
					"tag": "h3",
					"size": "small",
					"content": "How we bring a great strategy to life."
				}
			]
		},
		{
			"type": "container",
			"classList": ["content", "row"],
			"attributes": ["carousel"],
			"elements": [
				{
					"type": "snippet",
					"subtype": "multi",
					"dir": "marketing",
					"data": "content-marketing",
					"classList": ["shadow-box", "rounded-corners"]
				},
				{
					"type": "snippet",
					"subtype": "multi",
					"dir": "marketing",
					"data": "digital-marketing",
					"classList": ["shadow-box", "rounded-corners"]
				},
				{
					"type": "snippet",
					"subtype": "multi",
					"dir": "marketing",
					"data": "social_media-marketing",
					"classList": ["shadow-box", "rounded-corners"]
				},
				{
					"type": "snippet",
					"subtype": "multi",
					"dir": "marketing",
					"data": "search_engine-marketing",
					"classList": ["shadow-box", "rounded-corners"]
				},
				{
					"type": "snippet",
					"subtype": "multi",
					"dir": "marketing",
					"data": "email-marketing",
					"classList": ["shadow-box", "rounded-corners"]
				},
				{
					"type": "snippet",
					"subtype": "multi",
					"dir": "marketing",
					"data": "optimization-planning",
					"classList": ["shadow-box", "rounded-corners"]
				},
				{
					"type": "container",
					"attributes": ["paddle-section"],
					"elements": [
						{
							"type": "button",
							"subtype": "carousel-paddle",
							"scrollDir": "left",
							"classList": ["primary", "brand", "shadow-box"]
						},
						{
							"type": "button",
							"subtype": "carousel-paddle",
							"scrollDir": "right",
							"classList": ["primary", "brand", "shadow-box"]
						}
					]
				}
			]
		}
	]
}