{
	"type":"container",
	"id":"brandingCarousel",
	"classList":["container", "has_carousel"],
	"attributes":["anim-drop-fade", "custom-margin"],
	"properties":[
		{ "key":"--padding-mult", "value":"2"},
		{ "key":"--margin-mult", "value":"2"},
		{"key": "--card-width", "value": "350px"},
		{"key": "--card-width-mob", "value": "80vw"}
	],
	"elements":[ 
		{
			"type": "container",
			"classList": ["content", "text-center"],
			"attributes": ["custom-margin"],
			"properties": [
				{ "key":"--margin-mult", "value":"4"}
			],
			"elements": [
				{
					"type": "headline",
					"tag": "h3",
					"size": "small",
					"content": "All the components that make great branding."
				}
			]
		},
		{
			"type": "container",
			"classList": ["content", "row"],
			"attributes": ["carousel"],
			"elements": [
				{
					"type": "snippet",
					"subtype": "multi",
					"dir": "branding",
					"data": "logo-design",
					"classList": ["shadow-box", "rounded-corners"]
				},
				{
					"type": "snippet",
					"subtype": "multi",
					"dir": "branding",
					"data": "typography",
					"classList": ["shadow-box", "rounded-corners"]
				},
				{
					"type": "snippet",
					"subtype": "multi",
					"dir": "branding",
					"data": "color-palette",
					"classList": ["shadow-box", "rounded-corners"]
				},
				{
					"type": "snippet",
					"subtype": "multi",
					"dir": "branding",
					"data": "iconography",
					"classList": ["shadow-box", "rounded-corners"]
				},
				{
					"type": "snippet",
					"subtype": "multi",
					"dir": "branding",
					"data": "photography",
					"classList": ["shadow-box", "rounded-corners"]
				},
				{
					"type": "snippet",
					"subtype": "multi",
					"dir": "branding",
					"data": "guidelines",
					"classList": ["shadow-box", "rounded-corners"]
				},
				{
					"type": "container",
					"attributes": ["paddle-section"],
					"elements": [
						{
							"type": "button",
							"subtype": "carousel-paddle",
							"scrollDir": "left",
							"classList": ["primary", "brand", "shadow-box"]
						},
						{
							"type": "button",
							"subtype": "carousel-paddle",
							"scrollDir": "right",
							"classList": ["primary", "brand", "shadow-box"]
						}
					]
				}
			]
		}
	]
}