{
    "type": "container",
    "id": "tpExample",
    "classList": [
        "container",
        "module",
        "dark-mode",
        "has_bg",
        "row",
        "shadow-box"
    ],
    "attributes": [
        "anim-drop-fade",
        "bg-pos",
        "custom-margin"
    ],
    "properties": [
        {
            "key": "--bg-img",
            "value": "url('/files/images/bg/projects/tp-example-bg.jpg')"
        },
        {
            "key": "--bg-pos-dsk",
            "value": "0% 35%"
        },
        {
            "key": "--bg-pos-mob",
            "value": "center center"
        },
        {
            "key": "--padding-mult",
            "value": "2"
        },
        {
            "key": "--margin-mult",
            "value": "2"
        }
    ],
    "elements": [
        {
            "type": "container",
            "classList": [
                "container",
                "module",
                "row"
            ],
            "attributes": [
                "multi-dual",
                "custom-padding",
                {
                    "key": "color-overlay",
                    "value": "white"
                }
            ],
            "properties": [
                {
                    "key": "--overlay-opacity",
                    "value": "0"
                }
            ],
            "elements": [
                {
                    "type": "container",
                    "classList": [
                        "content",
                        "col",
