                    "properties": [
                        {
                            "key": "--flex-order",
                            "value": "1"
                        }
                    ],
                    "elements": [
                        {
                            "type": "image",
                            "alt": "tarak patel logo",
                            "size": "xlarge",
                            "src": "/files/images/fg/projects/tp-monogram.png",
                            "properties": [
                                {
                                    "key": "--size-mult",
                                    "value": "3"
                                }
                            ]
                        }
                    ]
                },
                {
                    "type": "container",
                    "classList": [
                        "content"
                    ],
                    "attributes": [
                        "custom-padding",
                        "order-adjust-mobile"
                    ],
                    "properties": [
                        {
                            "key": "--flex-order",
                            "value": "2"
                        }
                    ],
                    "elements": [
                        {
                            "type": "headline",
                            "tag": "h3",
                            "size": "large",
                            "content": "Recent project: Dr. Tarak Patel, Plastic Surgeon"
                        },
                        {
                            "type": "text",
                            "tag": "p",
                            "content": "Part website design, and part branding exercise. Check out what went into our latest project for Dr. Tarak Patel."
                        },
                        {
                            "type": "container",
                            "classList": [
                                "cta-section",
                                "row"
                            ],
                            "attributes": [
                                "h-left"
                            ],
                            "elements": [
                                {
                                    "type": "link",
                                    "classList": [
                                        "btn",
                                        "primary"
                                    ],
                                    "content": "Read about the project",
                                    "aria_label": "Click to learn more about Dr. Patel's website project.",
                                    "href": "https://medium.com/@blorentzen/project-update-web-design-and-development-for-dr-tarak-patel-8a5bba6af1e5",
                                    "target": "_blank"
                                }
                            ]
                        }
                    ]
                }
            ]
        }
